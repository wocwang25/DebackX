{
    "dataset": {
        "root": "../IIMT30k_Vi/Arial",
        "splits": ["train", "val", "test"],
        "source_lang": "en",
        "target_lang": "vi",
        "image_size": [512, 48]
    },
    "ocr": {
        "task": "recognize_text_inside_known_or_detected_box",
        "train_output_dir": "../outputs/ocr/en",
        "crop_padding": 2,
        "label_file": "labels.tsv",
        "backend": "trocr",
        "pretrained_model": "microsoft/trocr-base-printed",
        "checkpoint_dir": "../models/ocr-trocr-en",
        "batch_size": 32,
        "eval_batch_size": 16,
        "epochs": 8,
        "learning_rate": 5e-5,
        "weight_decay": 0.01,
        "warmup_ratio": 0.06,
        "max_target_length": 128,
        "num_workers": 4,
        "precision": "bf16",
        "eval_samples": 1500,
        "note": "Fine-tune TrOCR on cropped English text regions prepared from IIMT30k_Vi."
    },
    "translation": {
        "backend": "nllb",
        "pretrained_model": "facebook/nllb-200-distilled-600M",
        "source_code": "eng_Latn",
        "target_code": "vie_Latn",
        "checkpoint_dir": "../models/mt-nllb-en-vi",
        "train_source": "../IIMT30k_Vi/Arial/train/en/subtitle.txt",
        "train_target": "../IIMT30k_Vi/Arial/train/vi/subtitle.txt",
        "valid_source": "../IIMT30k_Vi/Arial/val/en/subtitle.txt",
        "valid_target": "../IIMT30k_Vi/Arial/val/vi/subtitle.txt",
        "batch_size": 16,
        "eval_batch_size": 16,
        "gradient_accumulation_steps": 2,
        "epochs": 6,
        "learning_rate": 2e-5,
        "weight_decay": 0.01,
        "warmup_ratio": 0.06,
        "max_source_length": 128,
        "max_target_length": 128,
        "num_workers": 2,
        "precision": "bf16",
        "eval_samples": 1500,
        "num_beams": 4,
        "note": "Fine-tune NLLB for English to Vietnamese subtitle translation."
    },
    "inpainting": {
        "backend": "dataset_background_for_benchmark_or_lama_for_real_images",
        "benchmark_background_dir": "{dataset_root}/{split}/background",
        "real_image_model": "LaMa",
        "mask_from": "ocr_text_box"
    },
    "render": {
        "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf",
        "min_font_size": 8,
        "max_font_size": 24,
        "text_color": [255, 255, 255],
        "box_color": [0, 0, 0],
        "box_alpha": 0.55,
        "horizontal_padding": 4,
        "vertical_padding": 2,
        "output_dir": "../outputs/rendered"
    }
}
