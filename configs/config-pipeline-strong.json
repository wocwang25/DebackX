{
    "dataset": {
        "root": "../IIMT30k_Vi/Arial",
        "splits": ["train", "val", "test"],
        "source_lang": "en",
        "target_lang": "vi",
        "image_size": [512, 48]
    },
    "translation": {
        "backend": "nllb",
        "pretrained_model": "facebook/nllb-200-1.3B",
        "source_code": "eng_Latn",
        "target_code": "vie_Latn",
        "checkpoint_dir": "../models/mt-nllb-1p3b-en-vi",
        "train_source": "../IIMT30k_Vi/Arial/train/en/subtitle.txt",
        "train_target": "../IIMT30k_Vi/Arial/train/vi/subtitle.txt",
        "valid_source": "../IIMT30k_Vi/Arial/val/en/subtitle.txt",
        "valid_target": "../IIMT30k_Vi/Arial/val/vi/subtitle.txt",
        "batch_size": 4,
        "eval_batch_size": 8,
        "gradient_accumulation_steps": 8,
        "epochs": 4,
        "learning_rate": 1e-5,
        "weight_decay": 0.01,
        "warmup_ratio": 0.06,
        "max_source_length": 128,
        "max_target_length": 128,
        "num_workers": 2,
        "precision": "bf16",
        "eval_samples": 1500,
        "num_beams": 5,
        "length_penalty": 1.0,
        "repetition_penalty": 1.0,
        "no_repeat_ngram_size": 0,
        "early_stopping": true,
        "note": "Strong MT preset: fine-tune NLLB 1.3B for English to Vietnamese subtitle translation."
    },
    "inpainting": {
        "backend": "dataset_background_for_benchmark_or_lama_for_real_images",
        "benchmark_background_dir": "{dataset_root}/{split}/background",
        "real_image_model": "LaMa",
        "mask_from": "ocr_text_box"
    },
    "real_image": {
        "detector": "paddleocr",
        "detector_gpu": true,
        "min_confidence": 0.35,
        "box_padding": 4,
        "recognizer": "paddleocr",
        "paddleocr_lang": "en",
        "paddleocr_version": "PP-OCRv5",
        "paddleocr_text_detection_model_name": "PP-OCRv5_server_det",
        "paddleocr_text_recognition_model_name": "en_PP-OCRv5_mobile_rec",
        "paddleocr_text_recognition_batch_size": 8,
        "paddleocr_text_det_limit_side_len": 4096,
        "paddleocr_text_det_limit_type": "max",
        "paddleocr_text_det_thresh": 0.25,
        "paddleocr_text_det_box_thresh": 0.5,
        "paddleocr_text_det_unclip_ratio": 1.8,
        "paddleocr_text_rec_score_thresh": 0.35,
        "paddleocr_use_doc_orientation": false,
        "paddleocr_use_doc_unwarping": false,
        "paddleocr_use_textline_orientation": false,
        "merge_text_regions": true,
        "merge_line_gap_ratio": 1.6,
        "merge_line_gap_px": 18,
        "mask_from_polygon": true,
        "mask_dilation": 3,
        "inpaint_backend": "opencv_telea",
        "inpaint_radius": 3,
        "mt_checkpoint": "../models/mt-nllb-1p3b-en-vi/best",
        "output_dir": "../outputs/real_images_strong",
        "metadata_suffix": ".json",
        "note": "Strong inference path for user-uploaded images. Uses PaddleOCR PP-OCRv5 for scene-text detection/recognition and merges nearby subtitle lines before translation."
    },
    "worker": {
        "host": "0.0.0.0",
        "port": 8000,
        "output_dir": "../outputs/worker_strong",
        "max_upload_mb": 20,
        "load_models_on_startup": true,
        "allowed_extensions": [".jpg", ".jpeg", ".png", ".webp"],
        "note": "FastAPI worker using PaddleOCR PP-OCRv5 and the strong MT checkpoint."
    },
    "render": {
        "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf",
        "min_font_size": 8,
        "max_font_size": 24,
        "text_color": [255, 255, 255],
        "adaptive_text_color": true,
        "fallback_to_contrast_text": true,
        "style_diff_threshold": 30,
        "style_min_pixels": 8,
        "stroke_width": 1,
        "stroke_color": [0, 0, 0],
        "adaptive_stroke_color": true,
        "box_color": [0, 0, 0],
        "box_alpha": 0.25,
        "horizontal_padding": 4,
        "vertical_padding": 2,
        "output_dir": "../outputs/rendered_strong"
    }
}
