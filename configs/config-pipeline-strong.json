{
    "dataset": {
        "root": "../IIMT30k_Vi/Arial",
        "splits": ["train", "val", "test"],
        "source_lang": "en",
        "target_lang": "vi",
        "image_size": [512, 48]
    },
    "ocr": {
        "task": "recognize_text_inside_known_or_detected_box",
        "train_output_dir": "../outputs/ocr/en",
        "crop_padding": 2,
        "label_file": "labels.tsv",
        "backend": "trocr",
        "pretrained_model": "microsoft/trocr-large-printed",
        "checkpoint_dir": "../models/ocr-trocr-large-en",
        "batch_size": 8,
        "eval_batch_size": 8,
        "epochs": 6,
        "learning_rate": 3e-5,
        "weight_decay": 0.01,
        "warmup_ratio": 0.06,
        "max_target_length": 128,
        "num_workers": 4,
        "precision": "bf16",
        "eval_samples": 1500,
        "note": "Strong OCR preset: fine-tune TrOCR large on cropped English text regions."
    },
    "translation": {
        "backend": "nllb",
        "pretrained_model": "facebook/nllb-200-1.3B",
        "source_code": "eng_Latn",
        "target_code": "vie_Latn",
        "checkpoint_dir": "../models/mt-nllb-1p3b-en-vi",
        "train_source": "../IIMT30k_Vi/Arial/train/en/subtitle.txt",
        "train_target": "../IIMT30k_Vi/Arial/train/vi/subtitle.txt",
        "valid_source": "../IIMT30k_Vi/Arial/val/en/subtitle.txt",
        "valid_target": "../IIMT30k_Vi/Arial/val/vi/subtitle.txt",
        "batch_size": 4,
        "eval_batch_size": 8,
        "gradient_accumulation_steps": 8,
        "epochs": 4,
        "learning_rate": 1e-5,
        "weight_decay": 0.01,
        "warmup_ratio": 0.06,
        "max_source_length": 128,
        "max_target_length": 128,
        "num_workers": 2,
        "precision": "bf16",
        "eval_samples": 1500,
        "num_beams": 5,
        "length_penalty": 1.0,
        "repetition_penalty": 1.0,
        "no_repeat_ngram_size": 0,
        "early_stopping": true,
        "note": "Strong MT preset: fine-tune NLLB 1.3B for English to Vietnamese subtitle translation."
    },
    "inpainting": {
        "backend": "dataset_background_for_benchmark_or_lama_for_real_images",
        "benchmark_background_dir": "{dataset_root}/{split}/background",
        "real_image_model": "LaMa",
        "mask_from": "ocr_text_box"
    },
    "real_image": {
        "detector": "easyocr",
        "detector_languages": ["en"],
        "detector_gpu": true,
        "detector_text_threshold": 0.5,
        "detector_low_text": 0.3,
        "detector_link_threshold": 0.4,
        "detector_width_ths": 0.7,
        "min_confidence": 0.1,
        "box_padding": 4,
        "mask_dilation": 5,
        "inpaint_backend": "opencv_telea",
        "inpaint_radius": 3,
        "ocr_checkpoint": "../models/ocr-trocr-large-en/best",
        "mt_checkpoint": "../models/mt-nllb-1p3b-en-vi/best",
        "output_dir": "../outputs/real_images_strong",
        "metadata_suffix": ".json",
        "note": "Strong inference path for user-uploaded images."
    },
    "worker": {
        "host": "0.0.0.0",
        "port": 8000,
        "output_dir": "../outputs/worker_strong",
        "max_upload_mb": 20,
        "load_models_on_startup": true,
        "allowed_extensions": [".jpg", ".jpeg", ".png", ".webp"],
        "note": "FastAPI worker using strong OCR/MT checkpoints."
    },
    "render": {
        "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf",
        "min_font_size": 8,
        "max_font_size": 24,
        "text_color": [255, 255, 255],
        "box_color": [0, 0, 0],
        "box_alpha": 0.55,
        "horizontal_padding": 4,
        "vertical_padding": 2,
        "output_dir": "../outputs/rendered_strong"
    }
}
